#!/usr/bin/env bash

# postinst creates this unmanaged convenience symlink. Remove it only for an
# actual uninstall (not an upgrade), and only while it still points to PiliMax,
# so package maintenance cannot delete a replacement file.
if [ "$1" = "remove" ] || [ "$1" = "purge" ] || [ "$1" = "disappear" ]; then
    if [ -L /usr/bin/pilimax ] &&
        [ "$(readlink /usr/bin/pilimax)" = "/opt/PiliMax/pilimax" ]; then
        rm -f -- /usr/bin/pilimax
    fi
fi

if [ "$1" = "remove" ] || [ "$1" = "purge" ]; then
    if [ -x /usr/bin/update-desktop-database ]; then
        echo "updating desktop database..."
        update-desktop-database -q /usr/share/applications || true
    fi

    if [ -x /usr/bin/gtk-update-icon-cache ]; then
        echo "updating icon cache..."
        gtk-update-icon-cache -q -t /usr/share/icons/hicolor || true
    fi

    if [ -x /usr/bin/update-mime-database ]; then
        echo "updating mime database..."
        update-mime-database /usr/share/mime || true
    fi
fi

if [ "$1" = "purge" ]; then
    # Debian maintainer scripts run as root and must not enumerate home
    # directories or remove per-user application data. Users may remove their
    # own data explicitly after uninstalling if they no longer need it.
    echo "PiliMax user data was preserved."
    echo "To remove it, each user may delete ~/.local/share/com.PiliMax.android manually."
fi

exit 0
